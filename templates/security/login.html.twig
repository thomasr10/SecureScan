{% extends 'base.html.twig' %}
{% block title %}Connexion{% endblock %}

{% block body %}
<div style="max-width:420px;margin:80px auto;padding:24px;background:#0b1220;border:1px solid #1f2a44;border-radius:12px;color:#fff">
  <h1 style="margin-bottom:16px">Connexion</h1>

  {% if error %}
    <div style="background:#3b0d0d;padding:10px;border-radius:8px;margin-bottom:12px">
      Identifiants invalides
    </div>
  {% endif %}

  <form method="post" action="{{ path('app_login') }}">
    <input type="email" name="_username" value="{{ last_username }}" placeholder="Email" required
           style="width:100%;padding:10px;border-radius:8px;margin-bottom:10px">
    <input type="password" name="_password" placeholder="Mot de passe" required
           style="width:100%;padding:10px;border-radius:8px;margin-bottom:10px">

    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
    <button type="submit" style="width:100%;padding:10px;border-radius:8px;background:#2f7df6;color:#fff">
      Se connecter
    </button>
  </form>

  <div style="margin-top:12px">
    <a href="{{ path('app_register') }}" style="color:#7dd3fc">Créer un compte</a>
  </div>
</div>
{% endblock %}