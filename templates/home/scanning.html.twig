{% extends 'base.html.twig' %}

{% block title %}SecureScan — Analyse en cours{% endblock %}

{% block body %}

<div class="scanning-page">
  <div class="scanning-glow"></div>
  <div class="grid-pattern" style="position:absolute;inset:0;pointer-events:none"></div>

  <div class="scanning-inner">

    <!-- Header -->
    <div class="scanning-header">
      <div class="scanning-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
      </div>
      <h1 class="scanning-title">Analyse du dépôt en cours…</h1>
      <p class="scanning-subtitle">Orchestration du pipeline de sécurité</p>
    </div>

    <!-- Barre de progression -->
    <div class="progress-card">
      <div class="progress-header">
        <span>Progression globale</span>
        <span id="progress-pct">0%</span>
      </div>
      <div class="progress-track">
        <div class="progress-bar" id="progress-bar"></div>
      </div>
    </div>

    <!-- Étapes -->
    <div class="steps-list" id="steps-list">

      <!-- Étape 1 -->
      <div class="step-card completed" id="step-1">
        <div class="step-inner">
          <span class="step-icon" id="step-1-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="#34D399" stroke-width="2">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
          </span>
          <div class="step-body">
            <div class="step-num">STEP 01</div>
            <div class="step-title">Clonage du dépôt</div>
            <div class="step-subtitle">Repository cloné avec succès</div>
          </div>
        </div>
      </div>

      <!-- Étape 2 -->
      <div class="step-card completed" id="step-2">
        <div class="step-inner">
          <span class="step-icon" id="step-2-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="#34D399" stroke-width="2">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
          </span>
          <div class="step-body">
            <div class="step-num">STEP 02</div>
            <div class="step-title">Détection du langage</div>
            <div class="step-subtitle">Langage détecté : JavaScript</div>
          </div>
        </div>
      </div>

      <!-- Étape 3 (avec sous-outils) -->
      <div class="step-card running" id="step-3">
        <div class="step-inner">
          <span class="step-icon" id="step-3-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="#60A5FA" stroke-width="2" class="animate-spin" style="animation:spin 1s linear infinite">
              <line x1="12" y1="2" x2="12" y2="6"/><line x1="12" y1="18" x2="12" y2="22"/>
              <line x1="4.93" y1="4.93" x2="7.76" y2="7.76"/><line x1="16.24" y1="16.24" x2="19.07" y2="19.07"/>
              <line x1="2" y1="12" x2="6" y2="12"/><line x1="18" y1="12" x2="22" y2="12"/>
              <line x1="4.93" y1="19.07" x2="7.76" y2="16.24"/><line x1="16.24" y1="7.76" x2="19.07" y2="4.93"/>
            </svg>
          </span>
          <div class="step-body">
            <div class="step-num">STEP 03</div>
            <div class="step-title" id="step-3-title">Analyse backend</div>
            <div class="step-subtitle">Exécution des outils de sécurité</div>

            <div class="tools-list">
              <p class="tools-label">Outils exécutés</p>
              <div class="tool-item completed" id="tool-0">
                <svg viewBox="0 0 24 24" fill="none" stroke="#34D399" stroke-width="2" width="16" height="16">
                  <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
                </svg>
                <span class="tool-name">npm audit</span>
              </div>
              <div class="tool-item completed" id="tool-1">
                <svg viewBox="0 0 24 24" fill="none" stroke="#34D399" stroke-width="2" width="16" height="16">
                  <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
                </svg>
                <span class="tool-name">ESLint Security</span>
              </div>
              <div class="tool-item running" id="tool-2">
                <svg viewBox="0 0 24 24" fill="none" stroke="#60A5FA" stroke-width="2" width="16" height="16"
                     style="animation:spin 1s linear infinite">
                  <line x1="12" y1="2" x2="12" y2="6"/><line x1="12" y1="18" x2="12" y2="22"/>
                  <line x1="4.93" y1="4.93" x2="7.76" y2="7.76"/><line x1="16.24" y1="16.24" x2="19.07" y2="19.07"/>
                  <line x1="2" y1="12" x2="6" y2="12"/><line x1="18" y1="12" x2="22" y2="12"/>
                  <line x1="4.93" y1="19.07" x2="7.76" y2="16.24"/><line x1="16.24" y1="7.76" x2="19.07" y2="4.93"/>
                </svg>
                <span class="tool-name">Semgrep</span>
                <div class="dots">
                  <span></span><span></span><span></span>
                </div>
              </div>
              <div class="tool-item pending" id="tool-3">
                <svg viewBox="0 0 24 24" fill="none" stroke="#475569" stroke-width="2" width="16" height="16">
                  <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                </svg>
                <span class="tool-name">TruffleHog</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Étape 4 -->
      <div class="step-card pending" id="step-4">
        <div class="step-inner">
          <span class="step-icon" id="step-4-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="#475569" stroke-width="2">
              <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
            </svg>
          </span>
          <div class="step-body">
            <div class="step-num">STEP 04</div>
            <div class="step-title">Mapping OWASP</div>
            <div class="step-subtitle">Catégorisation des vulnérabilités selon OWASP Top 10</div>
          </div>
        </div>
      </div>

      <!-- Étape 5 -->
      <div class="step-card pending" id="step-5">
        <div class="step-inner">
          <span class="step-icon" id="step-5-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="#475569" stroke-width="2">
              <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
            </svg>
          </span>
          <div class="step-body">
            <div class="step-num">STEP 05</div>
            <div class="step-title">Génération du Dashboard</div>
            <div class="step-subtitle">Compilation des résultats finaux</div>
          </div>
        </div>
      </div>

    </div><!-- /#steps-list -->
  </div>
</div>

<script>
const svgCheck = `<svg viewBox="0 0 24 24" fill="none" stroke="#34D399" stroke-width="2" width="24" height="24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`;
const svgSpin  = `<svg viewBox="0 0 24 24" fill="none" stroke="#60A5FA" stroke-width="2" width="24" height="24" style="animation:spin 1s linear infinite"><line x1="12" y1="2" x2="12" y2="6"/><line x1="12" y1="18" x2="12" y2="22"/><line x1="4.93" y1="4.93" x2="7.76" y2="7.76"/><line x1="16.24" y1="16.24" x2="19.07" y2="19.07"/><line x1="2" y1="12" x2="6" y2="12"/><line x1="18" y1="12" x2="22" y2="12"/><line x1="4.93" y1="19.07" x2="7.76" y2="16.24"/><line x1="16.24" y1="7.76" x2="19.07" y2="4.93"/></svg>`;
const svgClock = `<svg viewBox="0 0 24 24" fill="none" stroke="#475569" stroke-width="2" width="24" height="24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`;
const svgToolCheck = `<svg viewBox="0 0 24 24" fill="none" stroke="#34D399" stroke-width="2" width="16" height="16"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`;
const svgToolSpin = `<svg viewBox="0 0 24 24" fill="none" stroke="#60A5FA" stroke-width="2" width="16" height="16" style="animation:spin 1s linear infinite"><line x1="12" y1="2" x2="12" y2="6"/><line x1="12" y1="18" x2="12" y2="22"/><line x1="4.93" y1="4.93" x2="7.76" y2="7.76"/><line x1="16.24" y1="16.24" x2="19.07" y2="19.07"/><line x1="2" y1="12" x2="6" y2="12"/><line x1="18" y1="12" x2="22" y2="12"/><line x1="4.93" y1="19.07" x2="7.76" y2="16.24"/><line x1="16.24" y1="7.76" x2="19.07" y2="4.93"/></svg>`;
const svgToolClock = `<svg viewBox="0 0 24 24" fill="none" stroke="#475569" stroke-width="2" width="16" height="16"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`;
const dotsHtml = `<div class="dots"><span></span><span></span><span></span></div>`;

function setStepStatus(n, status) {
  const card = document.getElementById('step-' + n);
  const icon = document.getElementById('step-' + n + '-icon');
  card.className = 'step-card ' + status;
  if (status === 'completed') icon.innerHTML = svgCheck;
  else if (status === 'running') icon.innerHTML = svgSpin;
  else icon.innerHTML = svgClock;
}

function setToolStatus(idx, status) {
  const item = document.getElementById('tool-' + idx);
  const names = ['npm audit','ESLint Security','Semgrep','TruffleHog'];
  item.className = 'tool-item ' + status;
  let iconHtml = status === 'completed' ? svgToolCheck : (status === 'running' ? svgToolSpin : svgToolClock);
  const dots = status === 'running' ? dotsHtml : '';
  item.innerHTML = iconHtml + `<span class="tool-name">${names[idx]}</span>` + dots;
}

const timeline = [
  { time: 1500, fn: () => setToolStatus(2, 'completed') },
  { time: 1500, fn: () => setToolStatus(3, 'running') },
  { time: 3200, fn: () => setToolStatus(3, 'completed') },
  { time: 3200, fn: () => setStepStatus(3, 'completed') },
  { time: 3200, fn: () => setStepStatus(4, 'running') },
  { time: 5000, fn: () => setStepStatus(4, 'completed') },
  { time: 5000, fn: () => setStepStatus(5, 'running') },
  { time: 6800, fn: () => setStepStatus(5, 'completed') },
];

let elapsed = 0;
let tlIdx = 0;
const totalDuration = 8000;

const interval = setInterval(() => {
  elapsed += 50;
  const pct = Math.min(Math.round((elapsed / totalDuration) * 100), 100);
  document.getElementById('progress-pct').textContent = pct + '%';
  document.getElementById('progress-bar').style.width = pct + '%';

  while (tlIdx < timeline.length && elapsed >= timeline[tlIdx].time) {
    timeline[tlIdx].fn();
    tlIdx++;
  }

  if (elapsed >= totalDuration) {
    clearInterval(interval);
    // IMPORTANT: ici on redirige vers une route Symfony (pas dashboard.html)
    setTimeout(() => { window.location.href = '{{ path('app_dashboard') }}'; }, 600);
  }
}, 50);
</script>

{% endblock %}